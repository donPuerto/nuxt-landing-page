# Environment Variables

# n8n contact webhook URL used by server/api/contact.post.ts
# For local testing in n8n editor use /webhook-test/... and click "Listen for test event"
# For active production workflows use /webhook/...
NUXT_N8N_WEBHOOK_URL=

# Optional shared secret sent as x-webhook-secret header
NUXT_N8N_WEBHOOK_SECRET=

# Public chat webhook URL used by n8n chat widget in the client
NUXT_PUBLIC_N8N_CHAT_WEBHOOK_URL=
